# =============================================================================
# Decepticon Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# --- LLM API Keys ---
# Add keys for providers you want to use.
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here

# --- LiteLLM Proxy ---
# Master key for admin access to LiteLLM Proxy
LITELLM_MASTER_KEY=sk-decepticon-master

# Salt key for encrypting stored API keys (generate a strong random value)
LITELLM_SALT_KEY=sk-decepticon-salt-change-me

# --- PostgreSQL ---
POSTGRES_PASSWORD=decepticon

# --- Ports (optional) ---
# LANGGRAPH_PORT=2024
# LITELLM_PORT=4000
# POSTGRES_PORT=5432

# --- Decepticon Settings (optional overrides) ---
# DECEPTICON_DEBUG=true
# DECEPTICON_LOG_LEVEL=DEBUG
# DECEPTICON_LLM__PROXY_URL=http://localhost:4000
# DECEPTICON_MODEL_PROFILE=default  # default | high | test
